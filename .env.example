# WHA Auto Design AI — environment variables
# Copy this file to .env and fill in your actual keys.
# .env is in .gitignore and .dockerignore — it is NEVER committed or shipped.
#
# In production (HF Spaces):
#   Go to Space → Settings → Variables and secrets → Add secret
#   Set each of the variables below as a Secret (encrypted, not in logs).

# ── Google Gemini (Phase 2 image generation) ─────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── OpenRouter (Phase 1 VLM — optional, PHASE1_ENABLED=False by default) ──────
# Get key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# ── ConvertAPI (DWG → PNG conversion) ────────────────────────────────────────
# Get key: https://www.convertapi.com/a/auth
CONVERTAPI_SECRET=your-convertapi-secret-here
